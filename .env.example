# Admin authentication
ADMIN_PASSWORD=change-me-to-a-strong-password
SESSION_SECRET=change-me-to-a-long-random-string

# Formspree — create a form at https://formspree.io and paste the form ID
# Example: if your endpoint is https://formspree.io/f/xyzabc, use xyzabc
VITE_FORMSPREE_FORM_ID=your_formspree_form_id

# Neon PostgreSQL (https://console.neon.tech)
# DATABASE_URL = pooled connection (for the app / Prisma Client)
# DIRECT_URL   = direct connection (for prisma migrate) — copy from Neon "direct" connection string
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.region.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require"
